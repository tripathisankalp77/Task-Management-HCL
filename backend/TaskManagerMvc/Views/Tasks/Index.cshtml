@model List<TaskViewModel>
@{
    ViewData["Title"] = "My Tasks";
    Layout = "_Layout";
    var pending   = Model.Count(t => t.Status == "Pending");
    var completed = Model.Count(t => t.Status == "Completed");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-0 fw-bold">
            <i class="bi bi-list-task me-2 text-primary"></i>My Tasks
        </h4>
        <small class="text-muted">Server-rendered via Razor View (.NET MVC)</small>
    </div>
    <a href="/Tasks/Logout" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-box-arrow-right me-1"></i>Logout
    </a>
</div>

<!-- Summary cards -->
<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-0 bg-white shadow-sm text-center py-3">
            <div class="fs-2 fw-bold text-primary">@Model.Count</div>
            <div class="text-muted small">Total Tasks</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 bg-white shadow-sm text-center py-3">
            <div class="fs-2 fw-bold text-warning">@pending</div>
            <div class="text-muted small">Pending</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 bg-white shadow-sm text-center py-3">
            <div class="fs-2 fw-bold text-success">@completed</div>
            <div class="text-muted small">Completed</div>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-inbox fs-1 text-muted"></i>
        <p class="mt-3 text-muted">No tasks yet. Use the Angular app to create tasks.</p>
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Title</th>
                            <th>Description</th>
                            <th>Status</th>
                            <th>Due Date</th>
                            <th>Created</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in Model)
                        {
                            <tr class="task-card">
                                <td class="text-muted small">@task.Id</td>
                                <td class="fw-semibold">@task.Title</td>
                                <td class="text-muted small">
                                    @(string.IsNullOrEmpty(task.Description)
                                        ? "—"
                                        : (task.Description.Length > 60
                                            ? task.Description[..60] + "…"
                                            : task.Description))
                                </td>
                                <td>
                                    @if (task.Status == "Completed")
                                    {
                                        <span class="badge badge-completed rounded-pill">
                                            <i class="bi bi-check-circle me-1"></i>Completed
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-pending rounded-pill">
                                            <i class="bi bi-clock me-1"></i>Pending
                                        </span>
                                    }
                                </td>
                                <td class="text-muted small">
                                    @(task.DueDate.HasValue
                                        ? task.DueDate.Value.ToString("dd MMM yyyy")
                                        : "—")
                                </td>
                                <td class="text-muted small">
                                    @task.CreatedAt.ToString("dd MMM yyyy")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <p class="text-muted small mt-3 text-end">
        <i class="bi bi-info-circle me-1"></i>
        This page is server-side rendered by .NET MVC (Razor View).
        Use the <strong>Angular app</strong> for full CRUD operations.
    </p>
}
